# ─────────────────────────────────────────
# FleetPro v2 — Environment Variables
# Αντέγραψε αυτό το αρχείο ως .env.local
# ─────────────────────────────────────────

# Database (Supabase / Railway / Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fleetpro?schema=public"

# JWT Secret (τουλάχιστον 32 χαρακτήρες)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FleetPro"

# Super Admin (δημιουργείται με seed)
SUPER_ADMIN_EMAIL="superadmin@fleetpro.gr"
SUPER_ADMIN_PASSWORD="FleetPro2025!"

# Cloudinary (για φωτογραφίες οχημάτων/ζημιών/υπογραφές)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Stripe (για συνδρομές)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (δημιούργησε τα στο Stripe Dashboard)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@fleetpro.gr"
